{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": false,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "noEmit": true,
    "useDefineForClassFields": true,
    "types": ["vite/client"],
    "paths": {
      "@pkc/community-schema": ["./node_modules/@pkcprotocol/pkc-js/dist/browser/community/schema.d.ts"],
      "@pkc/comment-schema": ["./node_modules/@pkcprotocol/pkc-js/dist/browser/publications/comment/schema.d.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["src/test/**/*", "src/**/*.test.ts", "src/**/*.test.tsx"]
}
